# =========================================================================
# Conexao com o banco PostgreSQL + PostGIS (Neon).
# No Neon, copie a "Connection string" e mantenha o ?sslmode=require no final.
# Ex.: postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# =========================================================================
DATABASE_URL=

# Porta do servidor. No Render isto e definido automaticamente.
PORT=3000

# =========================================================================
# Camada de ORTOFOTO (tiles XYZ). Aceita os placeholders {z}/{x}/{y}.
# Ex.: https://meu-host.com/ortofoto/{z}/{x}/{y}.png
# Deixe vazio para usar a imagem de satelite publica (Esri) como referencia.
# Se SERVE_LOCAL_TILES=true e existir ./tiles/ortho, ela e exposta em
# /tiles/ortho/{z}/{x}/{y}.png automaticamente.
# =========================================================================
ORTHO_TILE_URL=
ORTHO_TILE_ATTRIBUTION=Ortofoto municipal
ORTHO_TILE_MINZOOM=0
ORTHO_TILE_MAXZOOM=22
SERVE_LOCAL_TILES=true

# =========================================================================
# Centro/zoom inicial do mapa (usado apenas se ainda nao houver dados
# carregados para calcular a extensao automaticamente).
# =========================================================================
MAP_CENTER_LAT=-22.0178
MAP_CENTER_LNG=-47.8908
MAP_ZOOM=14
